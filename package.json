{
  "name": "@nopaque/sdk",
  "version": "0.1.1",
  "description": "Official Node.js SDK for the Nopaque API",
  "license": "MIT",
  "author": "Nopaque <support@nopaque.co.uk>",
  "repository": {
    "type": "git",
    "url": "https://github.com/nopaque/node-sdk.git"
  },
  "homepage": "https://nopaque.co.uk/docs/sdks",
  "bugs": "https://github.com/nopaque/node-sdk/issues",
  "keywords": ["nopaque", "ivr", "sdk", "api"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --dir tests/integration",
    "lint": "eslint src tests",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",
    "eslint": "^8.57.0",
    "msw": "^2.3.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@9.6.0"
}
